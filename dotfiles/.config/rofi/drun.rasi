@theme "~/.config/rofi/general.rasi"

window{
    width:                      40%;
	background-color:           #292424be;
	padding:                    20px;
	border:                     2px;
    border-color:               var(accent-2);
    border-radius:              10px;
    font:                       "FiraCode Nerd Font 12";
}

inputbar {
	padding:                    10px;
    margin:                     0 0 10px 0;
}

prompt {
    color:                      var(orange-1);
}

entry {
	cursor-color:               var(red-2);
	color:                      var(red-1);
	cursor-width:               4px;
    border-radius:              0px;
}

listview {
    enabled:                    true;
    columns:                    2;
    lines:                      6;
    cycle:                      true;
    dynamic:                    true;
    scrollbar:                  false;
    layout:                     vertical;
    reverse:                    false;
    spacing:                    10px;
}

/*****----- Elements -----*****/

element {
	orientation:                horizontal;
	children:                   [element-icon, element-text];
    spacing:                    10px;
    padding:                    10px;
}

element selected {
    background-color:           var(primary-1);
}

element-text {
    color:                      var(accent-1);
    vertical-align:             0.5;
}

element-text selected{
    color:                      var(orange-1);
}

element-icon {
    size:                       32px;
}